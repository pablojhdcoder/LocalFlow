# LocalFlow backend configuration
# Copy to .env and adjust as needed. Restart the backend after changes.

# Server bind address and port
HOST=0.0.0.0
PORT=3000

# Root directory for audio, thumbnails, temp files, and SQLite DB
# Leave empty to use the default:
#   Windows: %USERPROFILE%\.localflow
#   macOS / Linux: ~/.localflow
LOCALFLOW_STORAGE_DIR=

# Maximum number of concurrent yt-dlp downloads
DOWNLOAD_QUEUE_CONCURRENCY=1

# yt-dlp audio format selector (e.g. bestaudio, m4a, opus)
YTDLP_AUDIO_FORMAT=bestaudio
